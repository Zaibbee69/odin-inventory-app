<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Toppings — Papa's Pizzeria</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --red: #c0392b;
      --red-dark: #962d22;
      --cream: #fdf6ec;
      --warm-white: #fffaf4;
      --charcoal: #1a1a1a;
      --muted: #7a6a5a;
      --border: #e8d9c5;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--warm-white);
      color: var(--charcoal);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── NAVBAR ── */
    nav {
      background: var(--charcoal);
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 20px rgba(0,0,0,0.3);
    }

    .nav-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 2rem;
      height: 64px;
      display: flex;
      align-items: center;
      gap: 2rem;
    }

    .nav-brand {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      font-weight: 900;
      color: var(--cream);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      letter-spacing: -0.02em;
    }

    .nav-links {
      display: flex;
      list-style: none;
      gap: 0.25rem;
      flex: 1;
    }

    .nav-links a {
      color: #bbb;
      text-decoration: none;
      font-size: 0.9rem;
      padding: 0.4rem 0.9rem;
      border-radius: 6px;
      transition: color 0.2s, background 0.2s;
    }

    .nav-links a:hover,
    .nav-links a.active {
      color: var(--cream);
      background: rgba(255,255,255,0.08);
    }

    .nav-search {
      display: flex;
      gap: 0.5rem;
      margin-left: auto;
    }

    .nav-search input {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 8px;
      padding: 0.45rem 1rem;
      color: var(--cream);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem;
      width: 200px;
      outline: none;
      transition: border-color 0.2s;
    }

    .nav-search input::placeholder { color: #888; }
    .nav-search input:focus { border-color: var(--red); }

    .nav-search button {
      background: var(--red);
      color: white;
      border: none;
      border-radius: 8px;
      padding: 0.45rem 1rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.2s;
    }

    .nav-search button:hover { background: var(--red-dark); }

    /* ── PAGE HEADER ── */
    .page-header {
      background: var(--charcoal);
      padding: 3rem 2rem 2.5rem;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .page-header-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 1.5rem;
      flex-wrap: wrap;
    }

    .page-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 4vw, 2.8rem);
      font-weight: 900;
      color: var(--cream);
      letter-spacing: -0.03em;
      line-height: 1.1;
    }

    .page-header h1 span { color: var(--red); }
    .page-header p { color: #999; font-size: 0.9rem; margin-top: 0.4rem; font-weight: 300; }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--red);
      color: white;
      border: none;
      border-radius: 10px;
      padding: 0.75rem 1.4rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s;
      white-space: nowrap;
    }

    .btn-primary:hover { background: var(--red-dark); transform: translateY(-1px); }

    /* ── MAIN ── */
    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2.5rem 2rem;
      flex: 1;
    }

    /* ── CATEGORY SECTION ── */
    .category-section { margin-bottom: 2.5rem; }

    .category-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .category-label {
      font-family: 'Playfair Display', serif;
      font-size: 1.15rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .category-count {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.75rem;
      font-weight: 500;
      color: var(--muted);
      background: var(--border);
      border-radius: 100px;
      padding: 0.15rem 0.6rem;
    }

    .category-divider {
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* ── TOPPING GRID ── */
    .toppings-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1rem;
    }

    .topping-card {
      background: white;
      border: 1.5px solid var(--border);
      border-radius: 14px;
      padding: 1.1rem 1.2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      transition: border-color 0.18s, box-shadow 0.18s, transform 0.18s;
    }

    .topping-card:hover {
      border-color: #d4bfac;
      box-shadow: 0 6px 20px rgba(0,0,0,0.07);
      transform: translateY(-2px);
    }

    .topping-name {
      font-weight: 500;
      font-size: 0.95rem;
    }

    .topping-actions {
      display: flex;
      gap: 0.3rem;
      flex-shrink: 0;
    }

    .action-btn {
      width: 30px;
      height: 30px;
      border-radius: 7px;
      border: 1.5px solid var(--border);
      background: white;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.8rem;
      text-decoration: none;
      color: var(--muted);
      transition: all 0.15s;
    }

    .action-btn:hover { border-color: #aaa; color: var(--charcoal); }
    .action-btn.delete:hover { border-color: var(--red); color: var(--red); background: #fff5f5; }

    /* ── EMPTY STATE ── */
    .empty-state {
      text-align: center;
      padding: 4rem 2rem;
      color: var(--muted);
    }

    .empty-state .empty-icon { font-size: 3rem; margin-bottom: 1rem; }

    /* ── FLASH MESSAGE ── */
    .flash {
      padding: 0.85rem 1.25rem;
      border-radius: 10px;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
      font-weight: 500;
    }

    .flash.success { background: #edfaf3; color: #1e7e4a; border: 1px solid #b7eacf; }
    .flash.error   { background: #fff5f5; color: var(--red);   border: 1px solid #f5c6c6; }

    /* ── FOOTER ── */
    footer {
      background: var(--charcoal);
      color: #777;
      text-align: center;
      padding: 1.2rem 2rem;
      font-size: 0.82rem;
    }

    @media (max-width: 700px) {
      .nav-search { display: none; }
      .toppings-grid { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 480px) {
      .toppings-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <%# ─── NAVBAR ─── %>
  <nav>
    <div class="nav-inner">
      <a class="nav-brand" href="/">🍕 Papa's Pizzeria</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/toppings" class="active">Toppings</a></li>
        <li><a href="/categories">Categories</a></li>
      </ul>
      <form class="nav-search" role="search" action="/menu/search" method="GET">
        <input type="search" placeholder="Search the menu..." name="search">
        <button type="submit">Search</button>
      </form>
    </div>
  </nav>

  <%# ─── PAGE HEADER ─── %>
  <div class="page-header">
    <div class="page-header-inner">
      <div>
        <h1>Topping <span>Library</span></h1>
        <p>Manage all toppings and their categories</p>
      </div>
      <a href="/toppings/new" class="btn-primary">+ Add Topping</a>
    </div>
  </div>

  <%# ─── MAIN ─── %>
  <div class="container">

    <%# Flash messages — set via res.locals in Express %>
    <% if (locals.flash) { %>
      <div class="flash <%= flash.type %>"><%= flash.message %></div>
    <% } %>

    <%# 
      Expected data from Express:
      toppingsByCategory — array of objects:
        [
          {
            category: { id, name },
            icon: '🥩',
            toppings: [ { id, name }, ... ]
          },
          ...
        ]
    %>

    <% if (toppingsByCategory.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">🍕</div>
        <p>No toppings yet. Add your first one!</p>
      </div>

    <% } else { %>
      <% toppingsByCategory.forEach(function(group) { %>
        <% if (group.toppings.length > 0) { %>
          <div class="category-section">
            <div class="category-header">
              <div class="category-label">
                <%= group.icon %> <%= group.category.name %>
              </div>
              <span class="category-count"><%= group.toppings.length %></span>
              <div class="category-divider"></div>
            </div>

            <div class="toppings-grid">
              <% group.toppings.forEach(function(topping) { %>
                <div class="topping-card">
                  <span class="topping-name"><%= topping.name %></span>
                  <div class="topping-actions">
                    <a href="/toppings/<%= topping.id %>/edit" class="action-btn" title="Edit">✏️</a>
                    <form action="/toppings/<%= topping.id %>?_method=DELETE" method="POST">
                      <button type="submit" class="action-btn delete" title="Delete"
                        onclick="return confirm('Remove <%= topping.name %>?')">🗑</button>
                    </form>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>
        <% } %>
      <% }); %>
    <% } %>

  </div>

  <footer>© 2026 Papa's Pizzeria. All rights reserved.</footer>

</body>
</html>
