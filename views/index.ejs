<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pizzeria</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --red: #c0392b;
        --red-dark: #962d22;
        --cream: #fdf6ec;
        --warm-white: #fffaf4;
        --charcoal: #1a1a1a;
        --muted: #7a6a5a;
        --border: #e8d9c5;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: "DM Sans", sans-serif;
        background: var(--warm-white);
        color: var(--charcoal);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* ── NAVBAR ── */
      nav {
        background: var(--charcoal);
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
      }

      .nav-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 2rem;
        height: 64px;
        display: flex;
        align-items: center;
        gap: 2rem;
      }

      .nav-brand {
        font-family: "Playfair Display", serif;
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--cream);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        letter-spacing: -0.02em;
      }

      .nav-brand .pizza-icon {
        font-size: 1.4rem;
      }

      .nav-links {
        display: flex;
        list-style: none;
        gap: 0.25rem;
        flex: 1;
      }

      .nav-links a {
        color: #bbb;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 400;
        padding: 0.4rem 0.9rem;
        border-radius: 6px;
        transition:
          color 0.2s,
          background 0.2s;
      }

      .nav-links a:hover,
      .nav-links a.active {
        color: var(--cream);
        background: rgba(255, 255, 255, 0.08);
      }

      .nav-search {
        display: flex;
        gap: 0.5rem;
        margin-left: auto;
      }

      .nav-search input {
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 8px;
        padding: 0.45rem 1rem;
        color: var(--cream);
        font-family: "DM Sans", sans-serif;
        font-size: 0.85rem;
        width: 200px;
        outline: none;
        transition:
          border-color 0.2s,
          background 0.2s;
      }

      .nav-search input::placeholder {
        color: #888;
      }
      .nav-search input:focus {
        border-color: var(--red);
        background: rgba(255, 255, 255, 0.12);
      }

      .nav-search button {
        background: var(--red);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 0.45rem 1rem;
        font-family: "DM Sans", sans-serif;
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.2s;
      }

      .nav-search button:hover {
        background: var(--red-dark);
      }

      /* ── HERO ── */
      .hero {
        position: relative;
        overflow: hidden;
        background: var(--charcoal);
        min-height: 480px;
        display: flex;
        align-items: center;
      }

      .hero-bg {
        position: absolute;
        inset: 0;
        background:
          radial-gradient(
            ellipse at 70% 50%,
            rgba(192, 57, 43, 0.25) 0%,
            transparent 60%
          ),
          radial-gradient(
            ellipse at 10% 80%,
            rgba(192, 57, 43, 0.12) 0%,
            transparent 50%
          );
      }

      /* Decorative circle */
      .hero-circle {
        position: absolute;
        right: -80px;
        top: 50%;
        transform: translateY(-50%);
        width: 520px;
        height: 520px;
        border-radius: 50%;
        background: radial-gradient(
          circle,
          rgba(192, 57, 43, 0.18) 0%,
          rgba(192, 57, 43, 0.04) 60%,
          transparent 70%
        );
        border: 1px solid rgba(192, 57, 43, 0.2);
      }

      .hero-circle::before {
        content: "🍕";
        position: absolute;
        font-size: 180px;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        filter: drop-shadow(0 20px 60px rgba(0, 0, 0, 0.5));
        animation: float 6s ease-in-out infinite;
      }

      @keyframes float {
        0%,
        100% {
          transform: translate(-50%, -50%) rotate(-5deg);
        }
        50% {
          transform: translate(-50%, -58%) rotate(5deg);
        }
      }

      .hero-content {
        position: relative;
        max-width: 1100px;
        margin: 0 auto;
        padding: 5rem 2rem;
        width: 100%;
      }

      .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(192, 57, 43, 0.15);
        border: 1px solid rgba(192, 57, 43, 0.3);
        border-radius: 100px;
        padding: 0.3rem 1rem;
        font-size: 0.78rem;
        font-weight: 500;
        color: #e8a090;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        animation: fadeUp 0.6s ease both;
      }

      h1 {
        font-family: "Playfair Display", serif;
        font-size: clamp(2.8rem, 6vw, 4.5rem);
        font-weight: 900;
        color: var(--cream);
        line-height: 1.05;
        letter-spacing: -0.03em;
        max-width: 540px;
        margin-bottom: 1.5rem;
        animation: fadeUp 0.6s 0.1s ease both;
      }

      h1 span {
        color: var(--red);
      }

      .hero-desc {
        font-size: 1.05rem;
        color: #aaa;
        line-height: 1.7;
        max-width: 440px;
        margin-bottom: 2.5rem;
        font-weight: 300;
        animation: fadeUp 0.6s 0.2s ease both;
      }

      /* ── MAIN LINKS ── */
      .main-links {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        animation: fadeUp 0.6s 0.3s ease both;
      }

      .main-links a {
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        padding: 1.1rem 1.5rem;
        border-radius: 12px;
        min-width: 210px;
        font-weight: 500;
        font-size: 0.95rem;
        transition:
          transform 0.2s,
          box-shadow 0.2s;
      }

      .main-links a:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4);
      }

      .link-menu {
        background: var(--red);
        color: white;
      }

      .link-menu:hover {
        background: var(--red-dark);
      }

      .link-order {
        background: rgba(255, 255, 255, 0.07);
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: var(--cream);
      }

      .link-label {
        font-weight: 500;
      }
      .link-arrow {
        font-size: 1.1rem;
      }

      /* ── CONTAINER / MAIN ── */
      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 2rem;
        flex: 1;
      }

      /* ── FEATURES STRIP ── */
      .features {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        margin: 3rem 0;
      }

      .feature {
        background: var(--cream);
        padding: 2rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .feature-icon {
        font-size: 1.8rem;
        margin-bottom: 0.25rem;
      }
      .feature-title {
        font-family: "Playfair Display", serif;
        font-size: 1.05rem;
        font-weight: 700;
      }

      .feature-desc {
        font-size: 0.85rem;
        color: var(--muted);
        line-height: 1.6;
      }

      /* ── FOOTER ── */
      footer {
        background: var(--charcoal);
        color: #777;
        text-align: center;
        padding: 1.2rem 2rem;
        font-size: 0.82rem;
        margin-top: auto;
      }

      /* ── ANIMATIONS ── */
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(18px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* ── RESPONSIVE ── */
      @media (max-width: 700px) {
        .nav-search {
          display: none;
        }
        .features {
          grid-template-columns: 1fr;
        }
        .hero-circle {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <nav>
      <div class="nav-inner">
        <a class="nav-brand" href="/">
          <span class="pizza-icon">🍕</span> Papa's Pizzeria
        </a>
        <ul class="nav-links">
          <li><a href="/" class="active">Home</a></li>
          <li><a href="/toppings">Toppings</a></li>
          <li><a href="/categories">Categories</a></li>
        </ul>
        <form
          class="nav-search"
          role="search"
          action="/menu/search"
          method="post"
        >
          <input type="search" placeholder="Search the menu..." name="search" />
          <button type="submit">Search</button>
        </form>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-bg"></div>
      <div class="hero-circle"></div>
      <div class="hero-content">
        <div class="hero-eyebrow">✦ Fresh · Hot · Delicious</div>
        <h1>Welcome to<br /><span>Papa's Pizzeria</span></h1>
        <p class="hero-desc">
          Handcrafted pizzas made with the finest ingredients. Browse our menu,
          explore categories, and find your perfect slice — all in one place.
        </p>
        <div class="main-links">
          <a href="/toppings" class="link-menu">
            <span class="link-label">View Toppings</span>
            <span class="link-arrow">→</span>
          </a>
          <a href="/categories" class="link-order">
            <span class="link-label">View Categories</span>
            <span class="link-arrow">→</span>
          </a>
        </div>
      </div>
    </section>

    <div class="container">
      <div class="features">
        <div class="feature">
          <div class="feature-icon">🔥</div>
          <div class="feature-title">Stone-Baked</div>
          <div class="feature-desc">
            Every pizza fired in our wood-burning oven for the perfect crispy
            crust.
          </div>
        </div>
        <div class="feature">
          <div class="feature-icon">🧀</div>
          <div class="feature-title">Premium Toppings</div>
          <div class="feature-desc">
            Sourced fresh daily — real mozzarella, imported tomatoes, artisan
            meats.
          </div>
        </div>
        <div class="feature">
          <div class="feature-icon">🛵</div>
          <div class="feature-title">Fast Delivery</div>
          <div class="feature-desc">
            Hot to your door in 30 minutes or less, guaranteed.
          </div>
        </div>
      </div>
    </div>

    <footer>© 2026 Pizzeria. All rights reserved.</footer>
  </body>
</html>
